generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  reports       Report[]
  // AES-256-GCM ciphertext of the user-configured DeepSeek API key (see lib/crypto.ts).
  // null until the user configures one on /dashboard/settings.
  deepseekApiKey String?
  // 用户自定义的发现关键词（JSON 字符串数组，如 ["llm","agent"]）。
  // null 时回落到内置 AI_TOPICS。控制「发现项目」时搜索哪些 GitHub topic。
  discoverKeywords String?
  // 用户自定义的分析提示词（明文）。null 时仅用内置系统提示词。
  // 分析时会拼接到 ANALYSIS_SYSTEM_PROMPT 之后。
  customPrompt String?
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id             String     @id @default(cuid())
  githubId       Int        @unique
  name           String
  fullName       String
  description    String?
  stars          Int
  forks          Int
  language       String?
  topics         String     @default("[]")
  license        String?
  homepage       String?
  readme         String?
  defaultBranch  String     @default("main")
  lastPushedAt   DateTime?
  lastAnalyzedAt DateTime?
  reports        Report[]
  favorites      Favorite[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Report {
  id            String   @id @default(cuid())
  projectId     String
  // 报告归属的用户。null = 迁移前的历史/预置报告（对普通用户隐藏）。
  // 每用户每项目只保留一份，靠 saveReport 的 deleteMany({ projectId, userId }) 维持。
  userId        String?
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary       String
  overview      String
  architecture  String?
  keyTechs      String?
  learningValue String?
  difficulty    String   @default("intermediate")
  rawResponse   String?
  generatedAt   DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}
